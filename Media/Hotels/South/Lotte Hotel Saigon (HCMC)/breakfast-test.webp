    <script>
      document.addEventListener("DOMContentLoaded", function() {
        //TODODELETE - 개발 반영 필요하지 않음
        // // 플로팅 레이어 팝업 클릭이벤트
        const $btnRecent = document.querySelector(".btn-recent");
        const $recentModal = document.querySelector(".modal-recent");
        const recentModal = etUI.components.Modal();

        if ($btnRecent && $recentModal) {
          recentModal.core.init($recentModal, {
            afterOpen() {
              $btnRecent.classList.add("on");
            },
            afterClose() {
              if ($btnRecent.classList.contains("on")) {
                $btnRecent.classList.remove("on");
              }
            },
          });

          $btnRecent.addEventListener("click", () => {
            $recentModal.ui.open();
          });
        }
      });

    </script>
