    <script>
      document.addEventListener("DOMContentLoaded", function() {
        //TODODELETE - 개발 반영 필요하지 않음
        // // 플로팅 레이어 팝업 클릭이벤트
        const $btnWish = document.querySelector(".btn-wish");
        const $wishModal = document.querySelector(".modal-wish");
        const wishModal = etUI.components.Modal();

        if ($btnWish && $wishModal) {
          wishModal.core.init($wishModal, {
            afterOpen() {
              $btnWish.classList.add("on");
            },
            afterClose() {
              if ($btnWish.classList.contains("on")) {
                $btnWish.classList.remove("on");
              }
            },
          });

          $btnWish.addEventListener("click", () => {
            $wishModal.ui.open();
          });
        }
      });

    </script>
