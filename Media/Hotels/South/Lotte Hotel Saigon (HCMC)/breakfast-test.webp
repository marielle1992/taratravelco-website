    <script>
      document.addEventListener("DOMContentLoaded", function() {
        //TODODELETE
        // 모달 인스턴스 생성
        const $alarmtModal = new etUI.components.Modal();
        $alarmtModal.core.init(".modal-alarm", {
          beforeOpen() {
            // $btnAlarm.classList.add("active");
          },
          beforeClose() {
            // $btnAlarm.classList.remove("active");
          },
        });
        // const $btnAlarm = document.querySelector(".btn-alarm");
        // 모달 초기화
        const $btnAlarm = document.querySelector(".header-util-wrap .btn-alarm");
        if ($btnAlarm) {
          $btnAlarm.addEventListener("click", () => {
            $alarmtModal.open();
          });
        }
      });

    </script>
