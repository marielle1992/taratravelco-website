<style id="wp-custom-css">
/* language font */
@font-face {
  font-family: Avo;             
  src: url(https://tmshotel.vn/wp-content/uploads/2023/05/UTM-Avo.ttf);
}

.translatepress-vi {
	font-family: 'Avo', sans-serif !important;
}

.translatepress-vi h1 {
	font-family: 'Avo', sans-serif !important;
}

.translatepress-vi h2 {
	font-family: 'Avo', sans-serif !important;
}

.translatepress-vi p {
	font-family: 'Avo', sans-serif !important;
}

.translatepress-vi a {
	font-family: 'Avo', sans-serif !important;
}

.translatepress-vi span {
	font-family: 'Avo', sans-serif !important;
}
/* end language font */

.heading-room span {
	color: var(--e-global-color-primary );
}

.mphb-room-type-gallery-wrapper #gallery-1 {
	display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between !important;
}
/* =====================================================
   FIX Elementor LANGUAGE submenu drop-up
   Website: tmshotel.vn
   PC only
===================================================== */

@media (min-width: 1024px) {

  /* Unlock header overflow */
  .elementor-location-header,
  .elementor-location-header * {
    overflow: visible !important;
  }

  /* Force Elementor submenu to open DOWN */
  .elementor-nav-menu .menu-item-has-children > .sub-menu,
  .elementor-nav-menu .has-submenu + .sub-menu {
    top: 100% !important;
    bottom: auto !important;
    transform: translateY(0) !important;
  }

  /* Prevent Elementor auto flip */
  .elementor-nav-menu .sub-menu {
    inset: auto !important;
  }
}


/* room detail */
.mphb-attribute-value  {
	display: flex;
	flex-wrap: wrap;
	margin-top: 12px
}

.mphb-attribute-value span {
	flex: 40% !important;
	text-align: left;
	margin-bottom: 8px;
}


@media only screen and (max-width: 768px) {
	.mphb-attribute-value span {
		flex: 100% !important;
		margin-bottom: 0px
	}
}

.wp-block-motopress-hotel-booking-wrapper {
	max-width: 100% !important;
	padding: 0;
}

.mphb-attribute-value span a {
	color: var(--e-global-color-12d338a)
}

/*
 * .mphb-single-room-type-attributes {
	background: var(--e-global-color-2144fd3);
	padding: 40px;
}
*/

.mphb-single-room-type-attributes{ 
	list-style-type: none;
}

.mphb-attribute-title {
	padding-bottom: 4px;
	border-bottom: 1px solid #3F3F3F;
	font-size: 24px
}

/* end room detail */

.elementor-nav-menu--layout-horizontal .elementor-nav-menu>li>.scroll-down, .elementor-nav-menu--layout-horizontal .elementor-nav-menu>li ul {
}

.elementor-sticky--active .elementor-nav-menu--layout-horizontal .elementor-nav-menu>li ul {
	top: 100% !important;
}

.elementor-sticky--active .elementor-nav-menu--layout-horizontal .elementor-nav-menu>li ul li {
	background-color: #fff
}

/* language switcher */
.trp-language-switcher > div {
	border: none;
	background-position: left;
	padding: 4px 0 3px 13px
}

.trp-language-switcher div a {
	font-family: century gothic;
	font-size: 14px;
	color: #7c7b7b
}

.trp-language-switcher {
	width: auto
}
/* end language switcher */

/* Amennity deactive */
.mphb-room-type-facilities {
	pointer-events: none;
}

.fullscreenBtn button:hover {
	background-color: var(--e-global-color-primary );
	color: #fff
}

.fullscreenBtn button {
	border-color: var(--e-global-color-primary );
	color: var(--e-global-color-primary );
}

a {
	color: #C29841
}.page-id-3054 .elementor-search-form__input {
    font-family: inherit;
}
</style>
